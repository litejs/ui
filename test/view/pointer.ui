
%js
	El.$b.captureTest = function(el, asObj) {
		var arr=[]
		, txt = el.textContent + " "
		, up = el.parentNode
		console.log("captureTest", asObj)
		El.on(up, "click", push(1), 0, asObj ? { capture: true } : true)
		El.on(up, "click", push(4), 0, asObj ? { capture: false } : false)
		El.on(el, "click", push(2), 0, asObj ? { capture: true } : true)
		El.on(el, "click", push(3), 0, asObj ? { capture: false } : false)
		function push(num) {
			return function() {
				if (arr.push(num) > 3) {
					El.txt(el, txt + (""+arr == "1,2,3,4") + " " + arr)
					arr = []
				}
			}
		}
	}

%view pointer public
anim-page
	.grid.b4
		.col.w6
			h2 Test touch 1
			.rel
				;css "background,height", ["#ddd","300px"]
				.abs.w3.h3 BTN
					;moveExample!
					;css "background", "#999"
					;css "height,width", "180px"
		.col.w6
			h2 Test touch SVG
			svg ;css "background,height,width", ["#ddd","300px","100%"]
				rect ;svgMoveExample!
					;set "x,y,width,height,fill", ["10","10","80","80","#999"]
	h2 Sort
	div ;draggableSort!"ul","li"; css "overflow","hidden"
		ul.sortCol
			li.anim First
			li.anim Second
			li.anim Third
		ul.sortCol
			li.anim Blue
	.grid.b4
		.col.w6
			h2 Sortable (pan)
			.sortable.grid.p2.no-select.rel
				@holdstart 'dragSort','.sortItem',['.col']
				@dblclick 'clone','.col'
				@contextmenu 'kill','.col'
				@sorted function(){console.log('SORTED')}
				@tap function(){console.log('TAP')}
				.col.w6>.sortItem First
				.col.w6>.sortItem Second
				.col.w6>.sortItem Third
				.col.w6>.sortItem Fourth
				.col.w6>.sortItem Fifth
		.col.w6
			h2 Sortable (handle)
			%el sortItem
				.col.w6
					.sortItem
						.grip ⠿
						span Item
			.sortable.grid.p2.no-select.rel
				@panstart 'dragSort','.grip',['.col']
				sortItem
				sortItem
				sortItem
				sortItem
				sortItem
	h2 Sortable (multi-col)
	.grid.b4.no-select
		@panstart 'dragSort','.card',['.card','.kanban']
		@sorted function(){console.log('SORTED KANBAN')}
		@tap function(){console.log('TAP')},'.card'
		.col.w4
			.kanban
				h3 To Do
				.card Alpha
				.card Beta
				.card Gamma
		.col.w4
			.kanban
				h3 In Progress
				.card Delta
		.col.w4
			.kanban
				h3 Done
				.card Epsilon
				.card Zeta
	h2 Events
	div Tap {tapCount}
		^$s!{tapCount:0}
		@tap function(e) {
			$s.tapCount = e.count
			El.render($el)
		}
	div Click fn {count0}
		^$s!{count0:1}
		@click function() {
			$s.count0++
			El.render($el)
		}
	div
		;$s!{count1:0}
		@click "inc", ["count1"]
		;txt "Click " + $s.count1
		;title! "Click " + count1
	div
		;$s!{count2:0}
		@click!"inc", ["count2"]
		;txt "One click " + $s.count2
	div
		;txt "Hover"
		@mouseover,mouseout "txt"
	div
		;$s! {count3:0}
		;txt "Wheel " + $s.count3
		;on "wheel", "txt", ["Wheel "]
	h2 addEventListener options
	div
		div inner boolean
			;captureTest!false
	div
		div inner object
			;captureTest!true

%css
	.sortCol{padding:2px;display:block;width:100px;margin:4px;border:1px solid #ccc;height:250px;float:left}
	.sortCol.is-active{border:1px solid green}
	.sortCol>li{list-style:none;display:block;margin:4px;border:1px solid #ddd;padding:4px}
	.kanban{
		min-height:120px;padding:8px;background:#f0f0f0;border-radius:4px;
		background-image: linear-gradient(168deg, transparent, rgb(0 0 0 / 25%));
	}
	.kanban h3{margin:0 0 8px}
	.card{padding:8px 12px;margin:4px 0;background:#fff;border:1px solid #ddd;border-radius:4px;cursor:grab}
